// Generated by Hytale UI Builder (https://hytale.ellie.au).
$C = "../Common.ui";
Group #MAIN {
  LayoutMode: Top;
  Background: (Color: #1e3d53);
  Anchor: (Width: 800, Height: 500);
  Group #TEXT {
    LayoutMode: Top;
    Background: (Color: #244964);
    Label #TITLE {
      Text: "STATISTICS";
      Style: (TextColor: #998033, FontSize: 45, RenderBold: true, HorizontalAlignment: Center);
    }
    Label #CREDITS {
      Text: "How many hours did you spend playing?";
      Style: (RenderUppercase: true, TextColor: #ffffff, FontSize: 20, RenderBold: true, HorizontalAlignment: Center);
    }
  }
  Group #SEP {
    LayoutMode: Top;
    Background: (Color: #998033);
    Anchor: (Height: 10);
  }
  Group #BUTTONS {
    LayoutMode: Top;
    Background: (Color: #1e3d53);
    Anchor: (Width: 505, Height: 330, Top: 5);
    Label #ROUNDSPLAYED {
      Anchor: (Top: 20);
      Text: "ROUNDS PLAYED:";
      Style: (RenderUppercase: true, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center);
    }
    Label #SANDBOXROUNDSPLAYED {
      Anchor: (Top: 1);
      Text: "SANDBOX ROUNDS PLAYED:";
      Style: (TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center);
    }
    Label #ROUNDSWON {
          Anchor: (Top: 1);
          Text: "ROUNDS WON:";
          Style: (TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center);
        }
    Label #TOTALKILLS {
      Anchor: (Top: 1);
      Text: "TOTAL KILLS:";
      Style: (TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center);
    }
    Label #TOTALBONUSKILLS {
      Anchor: (Top: 1);
      Text: "TOTAL BONUS KILLS:";
      Style: (TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center);
    }
    $C.@TextButton #RESETSTATS {
          Anchor: (Width: 115, Height: 50, Top: 10);
          Text: "RESET";
    }
    $C.@TextButton #BACK {
      Anchor: (Width: 115, Height: 50, Top: 40);
      Text: "BACK";
    }
  }
}
