// Generated by Hytale UI Builder (https://hytale.ellie.au).
$C = "../Common.ui";
Group #MAIN {
  LayoutMode: Top;
  Background: (Color: #1e3d53);
  Anchor: (Width: 800, Height: 500);
  Group #TEXT {
    LayoutMode: Top;
    Background: (Color: #244964);
    Label #TITLE {
      Text: "OPTIONS";
      Style: (TextColor: #998033, FontSize: 45, RenderBold: true, HorizontalAlignment: Center);
    }
    Label #CREDITS {
      Text: "Customise the experience!";
      Style: (TextColor: #ffffff, FontSize: 20, RenderBold: true, HorizontalAlignment: Center);
    }
  }
  Group #SEP {
    LayoutMode: Top;
    Background: (Color: #998033);
    Anchor: (Height: 10);
  }
  Group #BUTTONS {
    LayoutMode: Top;
    Background: (Color: #1e3d53);
    Anchor: (Width: 505, Height: 330, Top: 40);
    Label #SPIDERDESC {
      Text: "When turned on spiders can't spawn in waves.";
      Style: (TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center);
    }
    $C.@TextButton #SPIDERMODE {
      Background: (Color: #ffffff);
      Anchor: (Width: 80, Height: 50, Left: 0, Right: 0);
      Text: "ARACHNOPHOBIA MODE: OFF";
    }
    Label #EASYDESC {
      Anchor: (Top: 15);
      Text: "Passive regen boost for players.";
      Style: (TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center);
    }
    Label #EASYDESC2 {
      Anchor: (Top: 1);
      Text: "Ideal for beginners.";
      Style: (TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center);
    }
    $C.@TextButton #EASYMODE {
      Background: (Color: #ffffff);
      Anchor: (Width: 80, Height: 50, Left: 0, Right: 0, Top: 0);
      Text: "EASY MODE: OFF";
    }
    $C.@TextButton #BACK {
      Anchor: (Width: 115, Height: 50, Top: 80);
      Text: "BACK";
    }
  }
}
