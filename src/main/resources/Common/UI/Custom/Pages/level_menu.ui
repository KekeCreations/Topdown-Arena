      Background: (Color: #1e3d53);
      Anchor: (Width: 30, Height: 50);
    }
    Group #LEVEL25 {
      LayoutMode: Top;
      Anchor: (Width: 120, Height: 50);
      Group #CENTER25 {
        LayoutMode: Center;
        Label #RATING25 {
          Text: "0/3";
          Style: (TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center);
        }
        Group #IMGR25 {
          Anchor: (Width: 16, Height: 16);
          Padding: (Top: 16, Bottom: 16);
          AssetImage #IM25 {
            Anchor: (Width: 16, Height: 16);
            AssetPath: "Particles/Textures/Shapes/Star_Stylized.png";
          }
        }
      }
      $C.@TextButton #PLAYLEVEL25 {
        Background: (Color: #ffffff);
        Anchor: (Width: 60, Height: 30, Left: 0, Right: 0);
        Text: "LOCKED";
      }
    }
    Group #BORDERSEP10 {
      LayoutMode: Top;
      Background: (Color: #1e3d53);
      Anchor: (Width: 40, Height: 50);
    }
  }
  Group #ROWSEP5 {
    LayoutMode: Top;
    Background: (Color: #1e3d53);
    Anchor: (Height: 25);
  }
  $C.@TextButton #BACK {
    Background: (Color: #ffffff);
    Anchor: (Width: 80, Height: 50, Left: 0, Right: 0, Top: 0);
    Text: "BACK";
  }
}