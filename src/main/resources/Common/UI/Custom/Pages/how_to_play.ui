// Generated by Hytale UI Builder (https://hytale.ellie.au).
$C = "../Common.ui";
Group #MAIN {
  LayoutMode: Top;
  Background: (Color: #1e3d53);
  Anchor: (Width: 800, Height: 500);
  Group #TEXT {
    LayoutMode: Top;
    Background: (Color: #244964);
    Label #TITLE {
      Text: "HOW TO PLAY";
      Style: (TextColor: #998033, FontSize: 45, RenderBold: true, HorizontalAlignment: Center);
    }
    Label #CREDITS {
      Text: "This should help you";
      Style: (TextColor: #ffffff, FontSize: 20, RenderBold: true, HorizontalAlignment: Center);
    }
  }
  Group #SEP {
    LayoutMode: Top;
    Background: (Color: #998033);
    Anchor: (Height: 10);
  }
  Group #BUTTONS {
    LayoutMode: Top;
    Background: (Color: #1e3d53);
    Anchor: (Width: 505, Height: 330, Top: 5);
    Label #SUBTITLE1 {
      Text: "GAME EXPLAINED";
      Style: (FontSize: 20, TextColor: #998033, RenderBold: true, HorizontalAlignment: Center);
    }
    Label #EASYDESC {
      Anchor: (Top: 5);
      Text: "Each round lasts 60 seconds with 10 seconds of preparation time.";
      Style: (TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center);
    }
    Label #EASYDESC2 {
      Anchor: (Top: 1);
      Text: "Every level you select a new class.";
      Style: (TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center);
    }
    Label #EASYDESC3 {
      Anchor: (Top: 1);
      Text: "Class gear upgrades every 5 levels.";
      Style: (TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center);
    }
    Label #EASYDESC4 {
      Anchor: (Top: 1);
      Text: "YOU MUST KILL ENOUGH ENEMIES AND NOT DIE TO WIN";
      Style: (TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center);
    }
    Label #SUBTITLE2 {
      Anchor: (Top: 20);
      Text: "TIPS";
      Style: (FontSize: 20, TextColor: #998033, RenderBold: true, HorizontalAlignment: Center);
    }
    Label #TIPDESC {
      Anchor: (Top: 5);
      Text: "Tip #1: If you are stuck on a menu, dismiss the screen.";
      Style: (TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center);
    }
    Label #TIPDESC2 {
      Anchor: (Top: 1);
      Text: "Tip #2: Clicking menu buttons kills all entities in the world.";
      Style: (TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center);
    }
    Label #TIPDESC3 {
      Anchor: (Top: 1);
      Text: "Tip #3: Not all enemies can be hit with the same weapon.";
      Style: (TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center);
    }
    $C.@TextButton #BACK {
      Anchor: (Width: 115, Height: 50, Top: 40);
      Text: "BACK";
    }
  }
}