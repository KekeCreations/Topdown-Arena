// Generated by Hytale UI Builder (https://hytale.ellie.au).
$C = "../Common.ui";
Group #CLASSES {
  LayoutMode: Top;
  Background: (Color: #243847);
  Anchor: (Width: 1000, Height: 1000);
  Group #TEXT {
    LayoutMode: Top;
    Background: (Color: #1f3b4d);
    Label #TITLE {
      Text: "SANDBOX MODE";
      Style: (TextColor: #a9a151, FontSize: 40, RenderBold: true, RenderUppercase: true, HorizontalAlignment: Center);
    }
  }
  Group #BORDER {
    LayoutMode: MiddleCenter;
    Background: (Color: #795625);
    Anchor: (Height: 20);
  }
  Group #BORDER2 {
    LayoutMode: Top;
    Background: (Color: #243847);
    Anchor: (Height: 20);
  }
  Group #BORDERWA {
    LayoutMode: Top;
    Background: (Color: #243847);
    Anchor: (Height: 5);
  }
  Group #BODY {
    LayoutMode: Top;
    Background: (Color: #243847);
    Anchor: (Width: 1000, Height: 850);
    Group #MAINSEP {
      LayoutMode: Middle;
      Background: (Color: #243847);
      Anchor: (Height: 20);
    }
    Label #CLASSCHOICE {
      Text: "CLASS CHOICE";
      Style: (TextColor: #ffffff, FontSize: 20, RenderBold: true, HorizontalAlignment: Center);
    }
    Group #ROW2 {
      LayoutMode: Left;
      Background: (Color: #243847);
      Group #BORDERGAPBIG {
        LayoutMode: Top;
        Background: (Color: #243847);
        Anchor: (Width: 250);
      }
      Group #CLASS {
        LayoutMode: Middle;
        Background: (Color: #1d2d3a);
        Anchor: (Width: 200, Height: 200);
        Group #IMGROUP4 {
          Background: (Color: #192834);
          Anchor: (Width: 100, Height: 100);
          Padding: (Top: 16, Bottom: 16);
          AssetImage #CLASSIMAGE1 {
            Anchor: (Width: 100, Height: 100);
            AssetPath: "Icons/ItemsGenerated/Weapon_Sword_Iron.png";
          }
        }
        Label #CLASSTITLE {
          Text: "KNIGHT";
          Style: (TextColor: #a9a151, FontSize: 15, RenderBold: true, HorizontalAlignment: Center);
        }
        Label #DESC {
          Text: "CHARGE INTO BATTLE";
          Style: (TextColor: #ffffff, FontSize: 15, RenderBold: true, HorizontalAlignment: Center);
        }
        $C.@TextButton #CYCLECLASS {
          Anchor: (Width: 100, Height: 30);
          Text: "CYCLE";
        }
      }
      Group #CLASSSEP {
        LayoutMode: Middle;
        Background: (Color: #243847);
        Anchor: (Width: 100, Height: 20);
      }
      Group #CLASSLEVEL {
        LayoutMode: Middle;
        Background: (Color: #1d2d3a);
        Anchor: (Width: 200, Height: 200);
        Group #IMGROUP5 {
          Background: (Color: #192834);
          Anchor: (Width: 100, Height: 100);
          Padding: (Top: 16, Bottom: 16);
          AssetImage #CLASSLEVELIMAGE {
            Anchor: (Width: 100, Height: 100);
            AssetPath: "Icons/ItemsGenerated/Weapon_Sword_Iron.png";
          }
        }
        Label #CLASSLEVELTITLE {
          Text: "KNIGHT";
          Style: (TextColor: #a9a151, FontSize: 15, RenderBold: true, HorizontalAlignment: Center);
        }
        Label #DESCLEVEL {
          Text: "CHARGE INTO BATTLE";
          Style: (TextColor: #ffffff, FontSize: 15, RenderBold: true, HorizontalAlignment: Center);
        }
        $C.@TextButton #CYCLECLASSLEVEL {
          Anchor: (Width: 100, Height: 30);
          Text: "CYCLE";
        }
      }
    }
    Group #MAINSEP1 {
      LayoutMode: Middle;
      Background: (Color: #243847);
      Anchor: (Height: 20);
    }
    Group #MAINSEP2 {
      LayoutMode: Middle;
      Background: (Color: #243847);
      Anchor: (Height: 150);
    }
