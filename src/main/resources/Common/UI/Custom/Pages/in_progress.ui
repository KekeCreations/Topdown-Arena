// Generated by Hytale UI Builder (https://hytale.ellie.au).
$C = "../Common.ui";
Group #MAIN {
  LayoutMode: Top;
  Background: (Color: #1e3d53);
  Anchor: (Width: 800, Height: 500);
  Group #TEXT {
    LayoutMode: Top;
    Background: (Color: #244964);
    Label #TITLE {
      Text: "TOPDOWN ARENA";
      Style: (TextColor: #998033, FontSize: 45, RenderBold: true, HorizontalAlignment: Center);
    }
    Label #CREDITS {
      Text: "MADE BY KEKECREATIONS";
      Style: (TextColor: #ffffff, FontSize: 20, RenderBold: true, HorizontalAlignment: Center);
    }
  }
  Group #SEP {
    LayoutMode: Top;
    Background: (Color: #998033);
    Anchor: (Height: 10);
  }
  Group #BUTTONS {
    LayoutMode: Top;
    Background: (Color: #1e3d53);
    Anchor: (Height: 330, Top: 40);
    Label #HELLO {
      Text: "HELLO THERE!";
      Style: (TextColor: #ffffff, FontSize: 20, RenderBold: true, HorizontalAlignment: Center);
    }
    Label #DESC {
      Anchor: (Top: 10);
      Text: "A round is in progress right now, please wait!";
      Style: (TextColor: #ffffff, FontSize: 20, RenderBold: true, HorizontalAlignment: Center);
    }
    Label #DESCcopy {
      Anchor: (Top: 5);
      Text: "This screen will close when round is over!";
      Style: (TextColor: #ffffff, FontSize: 20, RenderBold: true, HorizontalAlignment: Center);
    }
    $C.@CancelTextButton #QUIT {
      Anchor: (Height: 50, Top: 20);
      Text: "QUIT";
    }
  }
}