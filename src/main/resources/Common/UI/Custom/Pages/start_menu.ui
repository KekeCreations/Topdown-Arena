$C = "../Common.ui";
Group #MAIN {
  LayoutMode: Top;
  Background: (Color: #1e3d53);
  Anchor: (Width: 800, Height: 500);
  Group #TEXT {
    LayoutMode: Top;
    Background: (Color: #244964);
    Label #TITLE {
      Text: "TOPDOWN ARENA";
      Style: (TextColor: #998033, FontSize: 45, RenderBold: true, HorizontalAlignment: Center);
    }
    Label #CREDITS {
      Text: "MADE BY KEKECREATIONS";
      Style: (TextColor: #ffffff, FontSize: 20, RenderBold: true, HorizontalAlignment: Center);
    }
  }
  Group #SEP {
    LayoutMode: Top;
    Background: (Color: #998033);
    Anchor: (Height: 10);
  }
  Group #BUTTONS {
    LayoutMode: Top;
    Background: (Color: #1e3d53);
    Anchor: (Width: 150, Height: 330, Left: 325, Top: 40);
    $C.@TextButton #PLAYLEVELS {
      Background: (Color: #ffffff);
      Anchor: (Width: 115, Height: 50, Left: 0, Right: 0);
      Text: "PLAY LEVELS";
    }
    $C.@TextButton #PLAYSANDBOX {
      Background: (Color: #ffffff);
      Anchor: (Width: 115, Height: 50, Left: 0, Right: 0, Top: 15);
      Text: "PLAY SANDBOX";
    }
    $C.@TextButton #OPTIONS {
      Background: (Color: #ffffff);
      Anchor: (Width: 115, Height: 50, Left: 0, Right: 0, Top: 15);
      Text: "OPTIONS";
    }
    $C.@TextButton #HOWTOPLAY {
      Anchor: (Height: 30, Top: 30);
      Text: "HOW TO PLAY";
    }
    $C.@CancelTextButton #QUIT {
      Anchor: (Height: 50, Top: 20);
      Text: "QUIT";
    }
  }
}